generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Role {
  USER
  DIRECTOR
  ADMISSION
}

enum TranslationNeeded {
  yes
  no
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      Role     @default(USER)
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model DocumentsManagement {
  id                String             @id @default(cuid())
  label             String
  internalCode      String
  fileType          String
  category          String
  translationNeeded TranslationNeeded  @default(no)
  required          Boolean            @default(false) @map("is_required")
  autoRenamePattern String
  notes             String?

  @@map("documents-management")
}


